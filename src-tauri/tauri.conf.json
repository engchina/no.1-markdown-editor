{
  "productName": "No.1 Markdown Editor",
  "version": "0.20.6",
  "identifier": "com.no1.markdown-editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev:web -- --host 127.0.0.1 --port 1420 --strictPort",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "No.1 Markdown Editor",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**/*.[3][gG][2]",
            "**/*.[3][gG][pP]",
            "**/*.[aA][aA][cC]",
            "**/*.[aA][iI][fF][fF]",
            "**/*.[aA][vV][iI]",
            "**/*.[aA][vV][iI][fF]",
            "**/*.[bB][mM][pP]",
            "**/*.[fF][lL][aA][cC]",
            "**/*.[gG][iI][fF]",
            "**/*.[jJ][pP][eE][gG]",
            "**/*.[jJ][pP][gG]",
            "**/*.[mM][4][aA]",
            "**/*.[mM][4][vV]",
            "**/*.[mM][kK][vV]",
            "**/*.[mM][oO][vV]",
            "**/*.[mM][pP][3]",
            "**/*.[mM][pP][4]",
            "**/*.[mM][pP][eE][gG]",
            "**/*.[mM][pP][gG]",
            "**/*.[oO][gG][aA]",
            "**/*.[oO][gG][gG]",
            "**/*.[oO][gG][vV]",
            "**/*.[oO][pP][uU][sS]",
            "**/*.[pP][nN][gG]",
            "**/*.[sS][rR][tT]",
            "**/*.[vV][tT][tT]",
            "**/*.[wW][aA][vV]",
            "**/*.[wW][eE][bB][aA]",
            "**/*.[wW][eE][bB][mM]",
            "**/*.[wW][eE][bB][pP]",
            "**/*.[wW][mM][aA]",
            "$AUDIO/**",
            "$DESKTOP/**",
            "$DOCUMENT/**",
            "$DOWNLOAD/**",
            "$PICTURE/**",
            "$VIDEO/**"
          ],
          "deny": [
            "**/.aws/**",
            "**/.config/**",
            "**/.gnupg/**",
            "**/.oci/**",
            "**/.ssh/**",
            "$APPDATA/**",
            "$APPCONFIG/**",
            "$APPLOCALDATA/**",
            "$CONFIG/**",
            "$HOME/.aws/**",
            "$HOME/.config/**",
            "$HOME/.gnupg/**",
            "$HOME/.oci/**",
            "$HOME/.ssh/**",
            "$LOCALDATA/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "rank": "Default"
      },
      {
        "ext": [
          "mdx"
        ],
        "name": "MDX Document",
        "description": "MDX document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "rank": "Default"
      },
      {
        "ext": [
          "txt"
        ],
        "name": "Plain Text Document",
        "description": "Plain text document",
        "role": "Editor",
        "mimeType": "text/plain",
        "rank": "Alternate"
      }
    ],
    "windows": {
      "wix": {
        "upgradeCode": "2A43089D-D7E9-533A-B6A3-43EAEF3F3D3F",
        "template": "wix/main.wxs"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
